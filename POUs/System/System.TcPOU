  <POU Name="System" Id="{003f6918-e202-45f7-9f35-d63b006dbbff}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM System
VAR

	
	Always_ON					:	BOOL	:=TRUE;	//상시ON
	Always_OFF					:	BOOL	:=FALSE;//상시OFF

	TON_ON  					: 	TON		; 		// 0.1초 ON 타이머 인스턴스
    TON_OFF 					:	TON		; 		// 0.1초 OFF 타이머 인스턴스
	TON2_ON  					: 	TON		; 		// 1초 ON 타이머 인스턴스
    TON2_OFF 					:	TON		;		 // 1초 OFF 타이머 인스턴스
	
	IO_Test						:	BOOL	;
	Lamp_Test_Green				:	BOOL	;
	Lamp_Test_Yellow			:	BOOL	;
	Lamp_Test_Red				:	BOOL	;
	Lamp_Test_Buzzer			:	BOOL	;
	Manual_Ready : BOOL;
	
	Buzzer						:	BOOL	;
	
	Moving_Motor_Wait_Position: BOOL;
	TEST02: INT;
	TEST06: BOOL;
	Axis02_Power_ON: TON;
	Axis03_Power_ON: TON;
	Axis04_Power_ON: TON;
END_VAR
]]></Declaration>
