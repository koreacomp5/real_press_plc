<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="FB_LRealRingQueue" Id="{a1b2c3d4-0001-4a01-9001-000000000001}" SpecialFunc="None">
    <Declaration><![CDATA[(* LREAL 링버퍼(FIFO) — 순차 push/pop. 좌표/엔코더 위치 등 범용 사용. *)
FUNCTION_BLOCK FB_LRealRingQueue
VAR CONSTANT
	CAPACITY : INT := 5;          // 링버퍼 칸 수(고정)
END_VAR
VAR
	buf  : ARRAY[0..4] OF LREAL;  // 기준점 저장(크기 = CAPACITY)
	head : INT;                   // pop 위치(가장 오래된 항목)
	tail : INT;                   // push 위치(다음 빈 칸)
	cnt  : INT;                   // 적재 수
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="Push" Id="{a1b2c3d4-0002-4a02-9002-000000000002}">
      <Declaration><![CDATA[METHOD Push : BOOL
VAR_INPUT
	val : LREAL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF cnt >= CAPACITY THEN
	Push := FALSE;            // 가득 — 거부
	RETURN;
END_IF
buf[tail] := val;
tail := (tail + 1) MOD CAPACITY;
cnt  := cnt + 1;
Push := TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Pop" Id="{a1b2c3d4-0003-4a03-9003-000000000003}">
      <Declaration><![CDATA[METHOD Pop : BOOL]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF cnt <= 0 THEN
	Pop := FALSE;            // 비어있음
	RETURN;
END_IF
head := (head + 1) MOD CAPACITY;
cnt  := cnt - 1;
Pop := TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="Clear" Id="{a1b2c3d4-0004-4a04-9004-000000000004}">
      <Declaration><![CDATA[METHOD Clear]]></Declaration>
      <Implementation>
        <ST><![CDATA[head := 0;
tail := 0;
cnt  := 0;]]></ST>
      </Implementation>
    </Method>
    <Property Name="Count" Id="{a1b2c3d4-0005-4a05-9005-000000000005}">
      <Declaration><![CDATA[PROPERTY Count : INT]]></Declaration>
      <Get Name="Get" Id="{a1b2c3d4-0006-4a06-9006-000000000006}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[Count := cnt;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="HeadValue" Id="{a1b2c3d4-0007-4a07-9007-000000000007}">
      <Declaration><![CDATA[PROPERTY HeadValue : LREAL]]></Declaration>
      <Get Name="Get" Id="{a1b2c3d4-0008-4a08-9008-000000000008}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[IF cnt > 0 THEN
	HeadValue := buf[head];
ELSE
	HeadValue := 0;
END_IF]]></ST>
        </Implementation>
      </Get>
    </Property>
  </POU>
</TcPlcObject>
