<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.16">
  <POU Name="Mastering" Id="{6e70edb0-906e-463b-bfbd-3cb34e22ea11}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM Mastering
VAR
	Move_Margin : LREAL;            // 목표 복귀거리 (mastering_vision_x - Axis02 대기위치), STEP20 진입 시 래치
	Start_Position : LREAL;         // 마스터링 시작 기준 위치
	Sensor_Position : LREAL;        // 비전 시작 센서 감지 위치
	Forward_Distance : LREAL;       // 시작점 기준 정방향 이동거리
	Shot_Position : LREAL;          // 정방향 카메라 촬영 위치
	Back_Distance : LREAL;          // Back 단계 이동량 (대기위치 기준 CCW 복귀량)
	Back_Start_Position : LREAL;    // Back 단계 시작(대기) 시점의 컨베이어 위치
	Vision_Start_Sensor_Trig  : R_TRIG;
	Back_Pos_Trig : R_TRIG;

	Mastering_Step : INT;

	fbCamPulse : TP;
	bCamTrigTP : BOOL;

END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[
Vision_Start_Sensor_Trig(CLK := GVL_System.Vision_Start_Sensor);
Back_Pos_Trig(CLK := GVL_Mastering.Back_Trig);

fbCamPulse(IN := bCamTrigTP, PT := T#200MS);
GVL_Mastering.Cam_Trig := fbCamPulse.Q;
bCamTrigTP := FALSE;


(* ──────────────────────────────────────────────────────────────
   [Back 트리거 처리]
   Back 트리거 상승 엣지 발생 시 현재 엔코더 위치를 Back_Shot_Position에 저장
   ────────────────────────────────────────────────────────────── *)
IF Back_Pos_Trig.Q THEN
    GVL_Mastering.Back_Shot_Position := GVL_Encoder.Real_Position;
END_IF


(* ==============================================================
   [초기화 처리] All_Initial + Manual_Mode 조건에서 전체 변수 리셋
   ============================================================== *)
IF GVL_System.All_Initial AND GVL_System.Manual_Mode THEN

    (* 내부 연산 변수 초기화 *)
    Start_Position      := 0;
    Sensor_Position     := 0;
    Forward_Distance    := 0;
    Shot_Position       := 0;
    Back_Distance       := 0;

    (* GVL 마스터링 변수 초기화 *)
    GVL_Mastering.mastering_vision_x      := 0;
    GVL_Mastering.Case_Length_Check_Start := FALSE;
    GVL_Mastering.Cam_Trig                := FALSE;
    GVL_Mastering.Back_Trig               := FALSE;
    GVL_Mastering.Case_Length             := 0;

    (* 스텝 초기화 *)
    Mastering_Step                        := 0;

END_IF


(* ==============================================================
   [마스터링 메인 시퀀스] Case_Length_Check_Start = TRUE 조건에서 실행
   ============================================================== *)
IF GVL_Mastering.Case_Length_Check_Start AND GVL_System.Manual_Mode THEN


    (* ── STEP 0 : 마스터링 시작 초기화 및 컨베이어 역방향 구동 ── *)
    IF  Mastering_Step = 0 THEN

        (* 내부 변수 초기화 *)
        Sensor_Position     := 0;
        Forward_Distance    := 0;
        Shot_Position       := 0;
        Back_Distance       := 0;

        (* GVL 마스터링 변수 초기화 *)
        GVL_Mastering.mastering_vision_x  := 0;
        GVL_Mastering.Cam_Trig            := FALSE;
        GVL_Mastering.Back_Trig           := FALSE;
        GVL_Mastering.Case_Length         := 0;

        (* 케이스 시작 위치 기록 후 컨베이어 역방향(CCW) 저속 구동 시작 *)
        Start_Position := GVL_Encoder.Real_Position;

        GVL_Conv.HMI_Motor_CCW       := TRUE;
        GVL_Conv.HMI_Motor_Low_Speed := TRUE;

        Mastering_Step := 5;

    END_IF


    (* ── STEP 5 : 비전 시작 센서 감지 → 케이스 길이 계산 ── *)
    IF Vision_Start_Sensor_Trig.Q AND Mastering_Step = 5 THEN

        (* 센서 감지 시점의 엔코더 위치 저장 → 케이스 길이 계산 *)
        Sensor_Position              := GVL_Encoder.Real_Position;
        GVL_Conv.HMI_Motor_CCW       := FALSE;
        GVL_Conv.HMI_Motor_Low_Speed := FALSE;

        GVL_Mastering.Case_Length := Start_Position - Sensor_Position;

        (* 케이스 길이가 유효할 때만 다음 스텝으로 진행 *)
        IF GVL_Mastering.Case_Length <> 0 THEN
            Mastering_Step := 10;
        END_IF

    END_IF


    (* ── STEP 10 : 컨베이어 정방향 구동 + 카메라 트리거 위치 탐색 ── *)
    IF GVL_Mastering.Case_Length <> 0 AND Mastering_Step = 10 THEN

        (* 컨베이어 정방향(CW) 저속 구동 *)
        GVL_Conv.HMI_Motor_CW        := TRUE;
        GVL_Conv.HMI_Motor_Low_Speed := TRUE;

        (* 현재 이동 거리 갱신 (기준위치 Start_Position 기준) *)
        Forward_Distance := GVL_Encoder.Real_Position - Start_Position;

        IF Forward_Distance >= 0 THEN

            (* 카메라 트리거 활성화 및 촬영 위치 저장 *)
            bCamTrigTP    := TRUE;
            Shot_Position := GVL_Encoder.Real_Position;

            (* 카메라 실제 트리거 신호 수신 시 다음 스텝으로 진행 *)
            IF GVL_Vision.Cam_Trigger AND Shot_Position <> 0 THEN
                Mastering_Step := 15;
            END_IF

        END_IF

    END_IF


    (* ── STEP 15 : 비전 결과 수신 대기 + 정지 조건 판단 ── *)
    IF Mastering_Step = 15 THEN

        (* 비전 결과 수신 완료 시 정지 *)
        IF GVL_Mastering.mastering_vision_x <> 0 THEN
            GVL_Conv.HMI_Motor_CW         := FALSE;
            GVL_Conv.HMI_Motor_Low_Speed  := FALSE;
            GVL_Conv.Conv_Motor_CW        := FALSE;
            GVL_Conv.Conv_Motor_Low_Speed := FALSE;
            (* Back 복귀 기준점(대기위치)과 목표 복귀거리(Move_Margin)를 진입 시점에 래치 *)
            Back_Start_Position := GVL_Encoder.Real_Position;
            Move_Margin         := GVL_Mastering.mastering_vision_x - GVL_Axis02.Wait_Position_Data;
            Mastering_Step := 20;
        END_IF

    END_IF


    (* ── STEP 20 : Axis04 마스터링 위치 이동 → 역방향 재촬영 ── *)
    IF Mastering_Step = 20 AND GVL_Mastering.Back_Trig THEN

        (* Axis04를 마스터링 위치로 이동 명령 *)
        GVL_Axis04.M_Mastering_Pos_Move := TRUE;

        IF GVL_Axis04.Mastering_Position THEN

            (* Axis04 마스터링 위치 도달 후 컨베이어 역방향 저속 구동 *)
            GVL_Conv.HMI_Motor_CCW       := TRUE;
            GVL_Conv.HMI_Motor_Low_Speed := TRUE;

            (* 대기위치(Back 시작점) 대비 역방향(CCW=엔코더 감소) 복귀 이동량 계산 *)
            Back_Distance := Back_Start_Position - GVL_Encoder.Real_Position;
            (* 대기위치~비전 X 거리(Move_Margin)만큼 복귀 시 재촬영 수행 *)
            IF Back_Distance >= Move_Margin THEN

                bCamTrigTP := TRUE;

                (* 카메라 트리거 + 실제 촬영 완료 시 위치 저장 후 다음 스텝으로 *)
                IF GVL_Mastering.Cam_Trig AND GVL_Vision.Cam_Trigger THEN
                    GVL_Mastering.Reshot_Position   := GVL_Encoder.Real_Position;
                    GVL_Axis04.M_Mastering_Pos_Move := FALSE;
                    GVL_Conv.HMI_Motor_CCW          := FALSE;
                    GVL_Conv.HMI_Motor_Low_Speed    := FALSE;
                    GVL_Conv.Conv_Motor_CCW         := FALSE;
                    GVL_Conv.Conv_Motor_Low_Speed   := FALSE;
                    Mastering_Step := 25;
                END_IF

            END_IF

        END_IF

    END_IF

    (* ── STEP 25 : 마스터링 완료 처리 ── *)
    IF Mastering_Step = 25 THEN

        (* 마스터링 관련 플래그 및 스텝 초기화 → 시퀀스 종료 *)
        GVL_Mastering.Case_Length_Check_Start := FALSE;
        GVL_Mastering.Cam_Trig                := FALSE;
        GVL_Mastering.Back_Trig               := FALSE;
        Mastering_Step                        := 0;

    END_IF


END_IF  (* Case_Length_Check_Start *)
]]></ST>
    </Implementation>
    <LineIds Name="Mastering">
      <LineId Id="210" Count="2" />
      <LineId Id="502" Count="1" />
      <LineId Id="213" Count="74" />
      <LineId Id="504" Count="2" />
      <LineId Id="288" Count="40" />
      <LineId Id="513" Count="0" />
      <LineId Id="516" Count="1" />
      <LineId Id="329" Count="19" />
      <LineId Id="351" Count="3" />
      <LineId Id="551" Count="0" />
      <LineId Id="359" Count="20" />
      <LineId Id="509" Count="0" />
      <LineId Id="380" Count="4" />
      <LineId Id="388" Count="2" />
      <LineId Id="518" Count="0" />
      <LineId Id="526" Count="0" />
      <LineId Id="586" Count="0" />
      <LineId Id="527" Count="0" />
      <LineId Id="552" Count="1" />
      <LineId Id="392" Count="0" />
    </LineIds>
  </POU>
