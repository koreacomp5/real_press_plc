<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.16">
  <POU Name="Vision_ST" Id="{eed554c4-fc1a-4baf-9f60-2c5a21e38ff5}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM Vision_ST
VAR
    CamTrigger : FB_CamTrigger;   // 캠트리거 파이프라인(센서→트리거, 연속 리얼타임)
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[
// ===== 캠트리거 파이프라인 (파이버 센서 → 카메라 트리거, 연속 리얼타임) =====
CamTrigger(
    Auto_Mode      := GVL_System.Auto_Mode,
    Fiber_Sensor   := GVL_System.Fiber_Sensor,
    Real_Position  := GVL_Encoder.Real_Position,
    Conveyor_CCW   := GVL_Encoder.Conveyor_CCW,
    Trigger_Length := GVL_Vision.Cam_Trigger_Length,
    Reset          := GVL_System.All_Initial);

// 오토모드 캠트리거만 구동 (마스터링은 Mastering.TcPOU 에서 별도 구동, 수동캠트리거 미사용)
IF GVL_System.Auto_Mode THEN GVL_Vision.Cam_Trigger := CamTrigger.Trigger; END_IF

GVL_Vision.Cam_Trig_Position := CamTrigger.Trig_Position;   // Target X 보정 기준(트리거 순간 엔코더)

// ===== Vision Light ON =====
GVL_Vision.Vision_Light_ON := GVL_System.Auto_Mode OR GVL_Vision.Vision_Light_ON;

]]></ST>
    </Implementation>
    <LineIds Name="Vision_ST">
      <LineId Id="2014" Count="0" />
      <LineId Id="2009" Count="0" />
      <LineId Id="8" Count="14" />
      <LineId Id="27" Count="1" />
    </LineIds>
  </POU>
</TcPlcObject>