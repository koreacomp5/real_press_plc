<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.16">
  <POU Name="Vision_ST" Id="{eed554c4-fc1a-4baf-9f60-2c5a21e38ff5}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM Vision_ST
VAR
    All_Initial_Trig         : R_TRIG;
    Vision_OK_Trig           : R_TRIG;
    Fiber_Sensor_Trig        : F_TRIG;
    Fiber_Sensor_Valid_TON   : TON;     // 파이버 센서 100ms 연속 ON = 유효 케이스 확인(디바운스)
    Cam_Trig_Pulse           : TP;                 // 캠트리거 0.1s 펄스 정형

    Case_Armed               : BOOL;    // 유효 케이스 무장(100ms 검증) → 후단에서 큐 push 대기, push/flush 시 해제
    Data_Initial             : BOOL;
    Status                   : BOOL;
    Step                     : UINT;    // 데이터 카피 시퀀스 스텝

    bCamDistReached          : BOOL;               // 이번 스캔 head 가 촬영거리 도달
    CamQueue                 : FB_LRealRingQueue;  // 캠트리거 기준점 큐(용량5)
    Last_Real_Position       : LREAL;              // 직전 스캔 엔코더 위치 (위치 불연속 감지용)
    RESET_JUMP_MIN           : LREAL := 100;       // 역방향 점프 임계(>1스캔 최대 이송) — 엔코더 스케일 맞춰 튜닝
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[All_Initial_Trig(CLK := GVL_Motion_Step.All_Initial);

Fiber_Sensor_Trig(CLK := GVL_System.Fiber_Sensor);
Vision_OK_Trig(CLK := GVL_Vision.Vision_OK);
Fiber_Sensor_Valid_TON(IN := GVL_System.Fiber_Sensor, PT := T#100MS);

// 무장(SET): 파이버 센서 100ms 연속 ON = 유효 케이스 (RESET 은 런10 push 시)
IF Fiber_Sensor_Valid_TON.Q THEN
    Case_Armed := TRUE;
END_IF

// ===== 런 10: Fiber_Sensor_Sensing — 후단(하강엣지)에서 기준점을 큐에 push =====
IF GVL_System.Auto_Mode AND Fiber_Sensor_Trig.Q AND Case_Armed THEN
    // push 성공 시에만 무장 해제. 큐 만재(거부)면 Case_Armed 유지 → 무음 유실 방지
    IF CamQueue.Push(GVL_Encoder.Real_Position) THEN
        Case_Armed := FALSE;
    END_IF
END_IF

// ===== 런 14: Cam_Trigger — head 기준점 + Cam_Trigger_Length 도달 시 1회 발동 + pop =====
bCamDistReached := FALSE;
IF GVL_System.Auto_Mode 
    AND CamQueue.Count > 0
    AND (CamQueue.HeadValue + GVL_Vision.Cam_Trigger_Length <= GVL_Encoder.Real_Position) THEN
    bCamDistReached := TRUE;
    GVL_Vision.Cam_Trig_Position := GVL_Encoder.Real_Position;  // Target X 보정 기준(트리거 순간 엔코더)
    CamQueue.Pop();
END_IF

// 오토모드 캠트리거만 구동 (마스터링은 Mastering.TcPOU 에서 별도 구동, 수동캠트리거 미사용)
// 모드 배타 가드 — Vision_ST(Auto)·Mastering(Manual)이 같은 출력을 안 다툼.
Cam_Trig_Pulse(IN := bCamDistReached, PT := T#0.1S);
IF GVL_System.Auto_Mode THEN
    GVL_Vision.Cam_Trigger := Cam_Trig_Pulse.Q;
END_IF

// ===== 런 15: 큐 flush =====
//  (1) 오토 이탈 / 컨베이어 역방향(Conveyor_CCW)
//  (2) 위치 불연속(엔코더 리셋 Set_Pos · 대형 역행 점프): head 기준점이 영구 도달불가가 되어
//      pop 정지 → stale 큐(Cam_Trig_Position 오류) 방지. 정상 전진/pop 시 Real 은
//      뒤로 점프하지 않으므로 오검출 없음. (RESET_JUMP_MIN 은 1스캔 최대 이송보다 크게 튜닝)
IF NOT GVL_System.Auto_Mode
   OR GVL_Encoder.Conveyor_CCW
   OR ((Last_Real_Position - GVL_Encoder.Real_Position) > RESET_JUMP_MIN) THEN
    CamQueue.Clear();
    Case_Armed := FALSE;
END_IF
Last_Real_Position := GVL_Encoder.Real_Position;

// ===== 런 6: Target X 위치 계산 (캠트리거 위치 기준 이동보정) =====
IF GVL_Vision.Data_Copy_Comp THEN
    GVL_Vision.Target_X_Real_Position_Data := GVL_Vision.Data_Buffer_X - (GVL_Encoder.Real_Position - GVL_Vision.Cam_Trig_Position);
END_IF

// Status 조건 — 오토모드에서만
Status :=  GVL_System.Auto_Mode AND GVL_System.Safety_ALL_OK;

IF Status THEN
    IF Step = 0 THEN
        IF Vision_OK_Trig.Q AND GVL_Vision.Run THEN
            Step := 1;
        END_IF
    END_IF

    IF Step = 1 THEN
        IF NOT GVL_Vision.Data_Copy_Comp AND GVL_Vision.Vision_OK THEN
            Step := 5;
        END_IF
    END_IF

    IF Step = 5 AND NOT GVL_Motion_Step.Press_Start THEN
        GVL_Vision.Data_Buffer_X := GVL_Vision.Data_Read_X;
        GVL_Vision.Data_Buffer_Y := GVL_Vision.Data_Read_Y;
        GVL_Vision.Data_Buffer_R := GVL_Vision.Data_Read_R;
        GVL_Vision.Data_Copy_Comp := TRUE;
        Step := 15;
    END_IF

    IF Step = 15 THEN
        Data_Initial := TRUE;
        Step := 0;
    END_IF

END_IF

// ===== 런 3: Vision 데이터 초기화 =====
IF Data_Initial OR GVL_System.All_Initial THEN
    GVL_Vision.Data_Read_X := 0;
    GVL_Vision.Data_Read_Y := 0;
    GVL_Vision.Data_Read_R := 0;
    GVL_Vision.Vision_OK := FALSE;
    Data_Initial := FALSE;
END_IF

// ===== 런 4: 속도/프레임 초기화 =====
IF GVL_Motion_Step.Axis02_Stop OR GVL_System.All_Initial THEN
    GVL_Vision.Average_Speed := 0;
    GVL_Vision.TotalSpeed := 0;
    GVL_Vision.FrameCount := 0;
    GVL_Vision.Get_Frame := 0;
END_IF

// ===== 런 7: 버퍼 초기화 =====
IF All_Initial_Trig.Q THEN
    GVL_Vision.Data_Buffer_X := 0;
    GVL_Vision.Data_Buffer_Y := 0;
    GVL_Vision.Data_Buffer_R := 0;
    GVL_Vision.Data_Copy_Comp := FALSE;
    GVL_Vision.Get_Frame_Time := 0;
    GVL_Vision.Target_X_Real_Position_Data := 0;
    GVL_Vision.Press_Speed := 0;
    GVL_Vision.Travel_Distance := 0;
    GVL_Vision.Moving_Time := 0;
    CamQueue.Clear();           // 시스템 초기화 시 캠트리거 큐 비움
    Case_Armed := FALSE;
END_IF

// ===== 런 16: Vision Light ON =====
GVL_Vision.Vision_Light_ON := GVL_System.Auto_Mode OR GVL_Vision.Vision_Light_ON;
]]></ST>
    </Implementation>
